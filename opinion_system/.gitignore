# ===========================================
# Python 运行时产生的二进制/缓存文件
# ===========================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ===========================================
# 数据库文件（本地运行产生的数据）
# ===========================================
*.db
*.sqlite
*.sqlite3

# ===========================================
# LLM 运行时配置（含 API Key，不要上传）
# ===========================================
llm_config.json

# ===========================================
# 虚拟环境 / 安装包依赖
# ===========================================
venv/
env/
.venv/
.env/
myenv/
*.egg-info/
dist/
build/

# pipenv
Pipfile.lock

# ===========================================
# IDE 和编辑器产生的文件
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================================
# 爬虫配置文件（含个人 Cookie，不要上传）
# 首次 clone 后会自动生成默认配置，在个人中心重新填入即可
# ===========================================
crawler_config.json

# ===========================================
# Jupyter / Notebook
# ===========================================
.ipynb_checkpoints/

# ===========================================
# 日志文件
# ===========================================
*.log
